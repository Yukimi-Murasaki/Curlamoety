				"{ \"text\": \"七咒之戒自带末影之戒的功能，点击查看\", \"color\":\"yellow\",\"underlined\": \"true\", \"clickEvent\": { \"action\": \"change_page\", \"value\": \"4645D10376CCBE6F\" } }"
